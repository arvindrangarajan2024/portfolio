---
import Layout from '~/layouts/PageLayout.astro';
import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { getPermalink } from '~/utils/permalinks';
import localAIFileOrganizerIcon from '~/assets/images/local-ai-file-organizer.png';
import arvindPhoto from '~/assets/images/arvind.png';

const metadata = {
  title: 'Arvind Rangarajan — Builder of AI tools & creative apps',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Fragment slot="header">
    <Header
      links={[
        { text: 'Home',     href: '#' },
        { text: 'About',    href: '#about' },
        { text: 'Projects', href: '#projects' },
        { text: 'Skills',   href: '#skills' },
        { text: 'Writing',  href: '#writing' },
        { text: 'GitHub',   href: 'https://github.com/arvindrangarajan2024', target: '_blank' },
        { text: 'Medium',   href: 'https://medium.com/@arvind-rangarajan', target: '_blank' },
      ]}
      actions={[
        {
          text: 'Connect on LinkedIn',
          href: 'https://www.linkedin.com/in/arvindrangarajan1/',
          target: '_blank',
        },
      ]}
      isSticky
      showToggleTheme
    />
  </Fragment>

  <!-- Hero -->
  <Hero
    id="hero"
    title="Arvind Rangarajan"
    tagline="Builder of AI tools & creative apps"
    actions={[
      {
        variant: 'primary',
        text: 'View Projects',
        href: '#projects',
        icon: 'tabler:arrow-down',
      },
      {
        text: 'LinkedIn',
        href: 'https://www.linkedin.com/in/arvindrangarajan1/',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
    ]}
  >
    <Fragment slot="subtitle">
      AI Product Marketer passionate about building tools that make AI practical and accessible. <br />
      I turn ideas into working products — from on-device LLM apps to creative software.
    </Fragment>
  </Hero>

  <!-- About -->
  <Content
    id="about"
    columns={3}
    items={[
      {
        icon: 'tabler:brand-github',
        callToAction: {
          target: '_blank',
          text: 'GitHub',
          href: 'https://github.com/arvindrangarajan2024',
        },
      },
      {
        icon: 'tabler:brand-linkedin',
        callToAction: {
          target: '_blank',
          text: 'LinkedIn',
          href: 'https://www.linkedin.com/in/arvindrangarajan1/',
        },
      },
      {
        icon: 'tabler:mail',
        callToAction: {
          text: 'Get in touch',
          href: getPermalink('/contact'),
        },
      },
    ]}
    image={{
      src: arvindPhoto,
      alt: 'Arvind Rangarajan',
      loading: 'eager',
      width: 320,
      height: 320,
    }}
  >
    <Fragment slot="content">
      <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">About me</h2>
      <p>
        I'm an AI Product Marketer who builds as well as markets — bridging the gap between cutting-edge AI technology
        and real-world usability. I believe the best way to market AI tools is to deeply understand them by building them.
      </p>
      <br />
      <p>
        My current focus is on local, privacy-first AI applications that run entirely on-device. No cloud, no
        subscriptions — just powerful AI that respects your data.
      </p>
      <br />
      <p>Find me here:</p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Projects -->
  <Content
    id="projects"
    title="Projects"
    subtitle="Things I've built — real software, shipped and available to use."
    isReversed
    items={[
      {
        title: 'What it does:',
        description:
          'Reads the actual content of your files and uses a local LLM (via Ollama) to classify and move them into meaningful category and subcategory folders — automatically. No cloud, no API keys.',
      },
      {
        title: 'Tech stack:',
        description:
          'Python · Tkinter · Ollama · PyInstaller · macOS .app bundle. Packaged as a native drag-to-install DMG.',
      },
    ]}
    image={{
      src: localAIFileOrganizerIcon,
      alt: 'Local AI File Organizer icon',
    }}
    callToAction={{
      target: '_blank',
      text: 'View on GitHub',
      icon: 'tabler:brand-github',
      href: 'https://github.com/arvindrangarajan2024',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Local AI File Organizer
      </h3>
      <p class="text-muted mb-4">
        A macOS desktop app that organises your files using on-device AI — everything stays on your machine.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Skills -->
  <Features3
    id="skills"
    title="Skills & tools"
    subtitle="What I bring to the table — from product thinking to hands-on building."
    columns={3}
    defaultIcon="tabler:point-filled"
    items={[
      {
        title: 'AI Product Marketing',
        description: 'Positioning, messaging, and go-to-market strategy for AI-powered products.',
      },
      {
        title: 'Local LLM / Ollama',
        description: 'Building privacy-first apps powered by on-device large language models.',
      },
      {
        title: 'Python',
        description: 'End-to-end application development — CLI tools, GUIs, APIs, and automation.',
      },
      {
        title: 'macOS App Development',
        description: 'Packaging Python apps as native .app bundles and DMGs using PyInstaller.',
      },
      {
        title: 'Product Strategy',
        description: 'Translating user needs into product decisions, roadmaps, and launch plans.',
      },
      {
        title: 'Creative Design',
        description: 'UI/UX thinking, design systems, and building polished user interfaces.',
      },
      {
        title: 'Git & Open Source',
        description: 'Version control, semantic versioning, release management, and GitHub workflows.',
      },
      {
        title: 'Content & Writing',
        description: 'Technical writing, product narratives, and long-form content for builders.',
      },
      {
        title: 'Fast Iteration',
        description: 'Shipping working software quickly, then refining based on real feedback.',
      },
    ]}
  />


  <!-- Medium Publications -->
  <Features2
    id="writing"
    title="Writing on Medium"
    subtitle="Thoughts on AI, product building, and the intersection of technology and creativity."
    tagline="Publications"
    columns={3}
    items={[
      {
        title: 'A Simple Framework for Building Agents Based on Large Language Models',
        description: 'A practical guide to designing and building LLM-powered agents — architecture, patterns, and lessons learned.',
        icon: 'tabler:brain',
        callToAction: {
          text: 'Read on Medium',
          href: 'https://medium.com/ai-builder/a-simple-framework-for-building-agents-based-on-large-language-models-4e0d5959dc7d',
          target: '_blank',
          icon: 'tabler:arrow-right',
        },
      },
      {
        title: 'Predicting NBA Player Performance with XGBoost: A Time Series Approach',
        description: 'Using XGBoost and time series analysis to forecast NBA player performance — a deep dive into sports analytics with ML.',
        icon: 'tabler:chart-line',
        callToAction: {
          text: 'Read on Medium',
          href: 'https://medium.com/ai-builder/predicting-nba-player-performance-with-xgboost-a-time-series-approach-7affce3ef614',
          target: '_blank',
          icon: 'tabler:arrow-right',
        },
      },
      {
        title: 'What is RLHF and How Can You Use It to Align Your Gen AI Models?',
        description: 'Breaking down Reinforcement Learning from Human Feedback — what it is, how it works, and how to apply it to align generative AI models.',
        icon: 'tabler:adjustments',
        callToAction: {
          text: 'Read on Medium',
          href: 'https://medium.com/ai-builder/what-is-rlhf-and-how-can-you-use-this-training-technique-to-align-your-gen-ai-models-closely-with-d1117bd4458c',
          target: '_blank',
          icon: 'tabler:arrow-right',
        },
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- CTA -->
  <CallToAction
    title="Let's build something together"
    subtitle="Interested in collaborating or have a project in mind? I'd love to hear from you."
    actions={[
      {
        variant: 'primary',
        text: 'Connect on LinkedIn',
        href: 'https://www.linkedin.com/in/arvindrangarajan1/',
        target: '_blank',
        icon: 'tabler:brand-linkedin',
      },
      {
        text: 'GitHub',
        href: 'https://github.com/arvindrangarajan2024',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
  />
</Layout>
